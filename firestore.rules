rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /mail_receipts/{document} {
      allow read, write: if request.auth != null;
    }
    match /outgoing_mail/{document} {
      allow read, write: if request.auth != null;
    }
    match /senders/{document} {
      allow read, write: if request.auth != null;
    }
    match /tool_manager_categories/{document} {
      allow read, write: if request.auth != null;
    }
    match /tool_manager_tools/{document} {
      allow read, write: if request.auth != null;
    }
    match /tool_manager_history/{document} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
